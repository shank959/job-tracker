# Copy to .env for local runs. In GitHub Actions, set these as repo secrets.

# --- Alert channel: set ALERT_CHANNEL in config/config.yaml (email|telegram|sms|slack|none)
# Email (SMTP) — for Gmail use an App Password, not your real password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=app-password-here
ALERT_EMAIL_TO=you@gmail.com

# Telegram (recommended: free, no carrier issues, works worldwide incl. SG)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_PHONE_TO=

# Slack incoming webhook (optional)
SLACK_WEBHOOK_URL=

# Optional LLM second-pass classifier (leave blank to disable)
ANTHROPIC_API_KEY=
